{
  "name": "flairestack-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,vite -c blue,green \"npm run server\" \"vite\"",
    "server": "node server/index.mjs",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "optimize:hero": "node scripts/optimize-hero.mjs",
    "generate:service-images": "node scripts/generate-service-image-manifest.mjs",
    "download:service-images": "node scripts/generate-service-image-manifest.mjs && node scripts/download-service-images.mjs",
    "sync:service-image-manifest": "node scripts/generate-service-image-manifest.mjs && node scripts/sync-service-image-manifest.mjs",
    "verify:supabase": "node scripts/verify-supabase.mjs"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@marsidev/react-turnstile": "^1.5.2",
    "@supabase/supabase-js": "^2.49.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^10.12.16",
    "lucide-react": "^1.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.10.1",
    "react-router-dom": "^7.15.1",
    "swiper": "^12.1.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.24",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.7",
    "vite": "^5.2.0"
  }
}
